    keyboard = [
        [InlineKeyboardButton("📊 MARKET STATUS", callback_data="status")],
        [InlineKeyboardButton("🔍 FORCE SIGNAL", callback_data="force")],
        [InlineKeyboardButton("💰 BALANCE", callback_data="balance")],
        [InlineKeyboardButton("📈 POSITION", callback_data="position")],
        [InlineKeyboardButton("🔴 CLOSE POSITION", callback_data="close")],
        [InlineKeyboardButton("🔄 REFRESH", callback_data="refresh")],
        [InlineKeyboardButton("❓ HELP", callback_data="help")],
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)
    
    welcome_msg = (
        "🤖 *GROQ MULTI-AGENT TRADING BOT*\n"
        "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
        "🎯 *5 AI Agents Working Together:*\n"
        "┌─────────────────────────────────┐\n"
        "│ 📊 Technical Analyst (RSI/MACD) │\n"
        "│ 📰 Sentiment Analyst (F&G)      │\n"
        "│ 📱 News & Social Analyst       │\n"
        "│ 💱 Exchange Flow Analyst       │\n"
        "│ 🛡️ Risk Manager (SL/TP)        │\n"
        "└─────────────────────────────────┘\n\n"
        "🧠 *Groq LLM Orchestrator* (Llama 3.1)\n"
        "   → Menggabungkan semua analisis\n\n"
        "⚡ *Auto-Trading Active*\n"
        "   → Analisis setiap 2 jam\n"
        "   → Eksekusi otomatis ke KuCoin\n\n"
        "📌 *Tekan tombol di bawah untuk mulai*"
    )
    await update.message.reply_text(welcome_msg, reply_markup=reply_markup, parse_mode='Markdown')

async def callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    data = query.data
    chat_id = update.effective_chat.id
    
    if data == "status":
        await context.bot.send_message(chat_id, "🔄 *Fetching market data...*", parse_mode='Markdown')
        tech, sent, news, exch, whale_data, risk_res, dec, price, balance, has_pos, pos = await get_analysis()
        
        msg = (
            "📊 *MARKET STATUS*\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
            f"💰 *Balance:* ${balance:.2f} USDT\n"
            f"📈 *BTC Price:* ${price:,.2f}\n\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
            "🤖 *AGENT SIGNALS*\n"
            f"┌─────────────────────────────────┐\n"
            f"│ 📊 Technical : {get_emoji(tech['signal'])} {tech['signal']} ({tech['confidence']}%)\n"
            f"│ 📰 Sentiment : {get_emoji(sent['signal'])} {sent['signal']} ({sent['confidence']}%)\n"
            f"│ 📱 News      : {get_emoji(news['signal'])} {news['signal']} ({news['confidence']}%)\n"
            f"│ 💱 Exchange  : {get_emoji(exch['signal'])} {exch['signal']} ({exch['confidence']}%)\n"
            f"└─────────────────────────────────┘\n\n"
            f"🛡️ *Risk Manager:* {'✅ CAN TRADE' if risk_res.get('can_trade') else '❌ CANNOT TRADE'}\n"
            f"📉 *Risk Score:* {risk_res.get('risk_score', 0)}/100\n"
        )
        
        if has_pos:
            msg += (
                "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
                "📌 *ACTIVE POSITION*\n"
                f"   Side: {'🟢 LONG' if pos['side'] == 'long' else '🔴 SHORT'}\n"
                f"   Entry: ${pos['entry']:.2f}\n"
                f"   Current: ${pos['current']:.2f}\n"
                f"   P&L: {pos['pnl']:+.2f} USDT\n"
            )
        
        msg += "\n━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
        msg += f"🕐 Last update: {datetime.now().strftime('%H:%M:%S')}"
        await context.bot.send_message(chat_id, msg, parse_mode='Markdown')
        
    elif data == "force":
        await context.bot.send_message(chat_id, "🔍 *Analyzing with 5 Agents...*", parse_mode='Markdown')
        tech, sent, news, exch, whale_data, risk_res, dec, price, balance, has_pos, pos = await get_analysis()
        
        msg = (
            "🎯 *FINAL TRADING SIGNAL*\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
            "📊 *Individual Agent Analysis:*\n"
            "┌─────────────────────────────────────────┐\n"
            f"│ 📊 Technical  : {tech['signal']} ({tech['confidence']}%)\n"
            f"│    └─ RSI: {tech.get('rsi', 'N/A')} | Trend: {tech.get('trend', 'N/A')}\n"
            f"│ 📰 Sentiment : {sent['signal']} ({sent['confidence']}%)\n"
            f"│    └─ Fear & Greed: {sent.get('fear_greed', 'N/A')}\n"
            f"│ 📱 News      : {news['signal']} ({news['confidence']}%)\n"
            f"│ 💱 Exchange  : {exch['signal']} ({exch['confidence']}%)\n"
            f"│    └─ {exch.get('reason', '')}\n"
            f"└─────────────────────────────────────────┘\n\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
            "🧠 *GROQ AI FINAL DECISION*\n"
            f"   ➜ *{dec.get('action', 'HOLD')}* ({dec.get('confidence', 50)}% confidence)\n"
            f"   📝 Reason: {dec.get('reason', 'N/A')}\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
            f"💰 Current Price: ${price:,.2f}\n"
        )
        
        if has_pos:
            msg += (
                f"\n⚠️ *EXISTING POSITION*\n"
                f"   Side: {pos['side'].upper()}\n"
                f"   Entry: ${pos['entry']:.2f}\n"
                f"   P&L: {pos['pnl']:+.2f} USDT\n"
            )
        
        msg += f"\n🛡️ *Risk Status:* {'✅ CAN TRADE' if risk_res.get('can_trade') else '❌ CANNOT TRADE'}"
        await context.bot.send_message(chat_id, msg, parse_mode='Markdown')
        
    elif data == "balance":
        balance = kucoin.get_balance()
        msg = (
            "💰 *BALANCE INFORMATION*\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
            f"💵 *Available Balance:*\n"
            f"   ➜ ${balance:.2f} USDT\n\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
            "📊 *Trading Limits:*\n"
            f"   • Min margin: $2.66 (1 contract)\n"
            f"   • Recommended: $10-20\n"
            f"   • Max leverage: 25x"
        )
        await context.bot.send_message(chat_id, msg, parse_mode='Markdown')
        
    elif data == "position":
        pos = kucoin.get_position()
        if pos['has_position']:
            msg = (
                "📈 *ACTIVE POSITION DETAILS*\n"
                "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
                f"📌 *Side:* {'🟢 LONG' if pos['side'] == 'long' else '🔴 SHORT'}\n"
                f"💰 *Entry Price:* ${pos['entry']:.2f}\n"
                f"📊 *Current Price:* ${pos['current']:.2f}\n"
                f"📉 *P&L:* {pos['pnl']:+.2f} USDT\n"
                f"📦 *Size:* {pos['size']} contract(s)\n\n"
                "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
                "🎯 *Risk Management:*\n"
                f"   🛡️ Stop Loss: -1.5%\n"
                f"   🎯 Take Profit: +3%"
            )
        else:
            msg = "📌 *No active position*\n\nUse FORCE SIGNAL to get trading signals."
        await context.bot.send_message(chat_id, msg, parse_mode='Markdown')
        
    elif data == "close":
        pos = kucoin.get_position()
        if pos['has_position']:
            await context.bot.send_message(chat_id, "🔄 *Closing position...*", parse_mode='Markdown')
            result = kucoin.close_position()
            if result:
                msg = (
                    "✅ *POSITION CLOSED*\n"
                    "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
                    f"📌 Side: {pos['side'].upper()}\n"
                    f"💰 Exit Price: ${pos['current']:.2f}\n"
                    f"📊 Final P&L: {pos['pnl']:+.2f} USDT"
                )
            else:
                msg = "❌ *Failed to close position*\nPlease check KuCoin connection."
        else:
            msg = "⚠️ *No active position to close*"
        await context.bot.send_message(chat_id, msg, parse_mode='Markdown')
        
    elif data == "refresh":
        await context.bot.send_message(chat_id, "🔄 *Refreshing data...*", parse_mode='Markdown')
        tech, sent, news, exch, whale_data, risk_res, dec, price, balance, has_pos, pos = await get_analysis()
        msg = (
            "✅ *DATA REFRESHED*\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
            f"💰 Balance: ${balance:.2f}\n"
            f"📈 BTC Price: ${price:,.2f}\n"
            f"🤖 Last Signal: {dec.get('action', 'HOLD')} ({dec.get('confidence', 50)}%)\n"
            f"🛡️ Risk: {'CAN TRADE' if risk_res.get('can_trade') else 'CANNOT TRADE'}"
        )
        await context.bot.send_message(chat_id, msg, parse_mode='Markdown')
        
    elif data == "help":
        msg = (
            "❓ *BOT COMMANDS & FEATURES*\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n\n"
            "📊 *MARKET STATUS* - Lihat semua sinyal agent\n"
            "🔍 *FORCE SIGNAL* - Analisis real-time (5 agents + Groq)\n"
            "💰 *BALANCE* - Cek saldo KuCoin\n"
            "📈 *POSITION* - Detail posisi aktif\n"
            "🔴 *CLOSE POSITION* - Tutup posisi manual\n"
            "🔄 *REFRESH* - Update data terbaru\n\n"
            "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n"
            "⚡ *AUTO-TRADING*\n"
            "   • Analisis otomatis setiap 2 jam\n"
            "   • Eksekusi sinyal ke KuCoin\n"
            "   • SL: 1.5% | TP: 3%\n\n"
            "📡 *Powered by:*\n"
            "   • Groq AI (Llama 3.1)\n"
            "   • 5 Specialized Agents\n"
            "   • KuCoin Futures API"
        )
        await context.bot.send_message(chat_id, msg, parse_mode='Markdown')

def main():
    app = Application.builder().token(TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    app.add_handler(CallbackQueryHandler(callback))
    logger.info("Bot started with 5 agents!")
    asyncio.create_task(monitor_sltp_loop())
    app.run_polling()

if __name__ == "__main__":
    main()

