async def send_telegram_alert(message):
    """Kirim alert ke Telegram"""
    try:
        from telegram import Bot
        token = os.getenv('TELEGRAM_BOT_TOKEN')
        chat_id = os.getenv('TELEGRAM_CHAT_ID')
        if token and chat_id:
            bot = Bot(token=token)
            await bot.send_message(chat_id, message, parse_mode='Markdown')
            logger.info(f"Alert sent: {message[:50]}...")
    except Exception as e:
        logger.error(f"Send alert error: {e}")

async def monitor_sltp_loop():
    """Loop monitoring posisi setiap 10 detik untuk eksekusi SL/TP otomatis"""
    logger.info("🟢 SL/TP Monitor started - checking every 10 seconds")
    while True:
        try:
            position = kucoin.get_position()
            
            if position['has_position']:
                entry = position['entry']
                current = position['current']
                side = position['side']
                pnl = position['pnl']
                
                if side == 'long':
                    sl_price = entry * 0.985
                    tp_price = entry * 1.03
                    
                    if current <= sl_price:
                        logger.info(f"🔴 STOP LOSS HIT! LONG at ${current:.2f}")
                        result = kucoin.close_position()
                        if result:
                            await send_telegram_alert(f"🔴 STOP LOSS HIT!\nEntry: ${entry:.2f}\nExit: ${current:.2f}\nPnL: {pnl:+.2f} USDT")
                        break
                    elif current >= tp_price:
                        logger.info(f"🎯 TAKE PROFIT HIT! LONG at ${current:.2f}")
                        result = kucoin.close_position()
                        if result:
                            await send_telegram_alert(f"🎯 TAKE PROFIT HIT!\nEntry: ${entry:.2f}\nExit: ${current:.2f}\nPnL: {pnl:+.2f} USDT")
                        break
                
                else:
                    sl_price = entry * 1.015
                    tp_price = entry * 0.97
                    
                    if current >= sl_price:
                        logger.info(f"🔴 STOP LOSS HIT! SHORT at ${current:.2f}")
                        result = kucoin.close_position()
                        if result:
                            await send_telegram_alert(f"🔴 STOP LOSS HIT!\nEntry: ${entry:.2f}\nExit: ${current:.2f}\nPnL: {pnl:+.2f} USDT")
                        break
                    elif current <= tp_price:
                        logger.info(f"🎯 TAKE PROFIT HIT! SHORT at ${current:.2f}")
                        result = kucoin.close_position()
                        if result:
                            await send_telegram_alert(f"🎯 TAKE PROFIT HIT!\nEntry: ${entry:.2f}\nExit: ${current:.2f}\nPnL: {pnl:+.2f} USDT")
                        break
            
            await asyncio.sleep(10)
            
        except Exception as e:
            logger.error(f"Monitor error: {e}")
            await asyncio.sleep(10)

news_social = NewsSocialAgent()
exchange = ExchangeAgent()
whale = WhaleAgent()
risk = RiskAgent()
groq = GroqOrchestrator(os.getenv('GROQ_API_KEY'))
kucoin = KuCoinFutures(
    api_key=os.getenv('KUCOIN_API_KEY'),
    api_secret=os.getenv('KUCOIN_API_SECRET'),
    api_passphrase=os.getenv('KUCOIN_API_PASSPHRASE')
)

async def get_analysis():
    price = kucoin.get_price()
    balance = kucoin.get_balance()
    position = kucoin.get_position()
    has_position = position['has_position']
    
    tech = await technical.analyze()
    sent = await sentiment.analyze()
    news = await news_social.analyze()
    exch = await exchange.analyze()
    whale_data = await whale.analyze()
    risk_res = await risk.analyze(balance, has_position, position if has_position else None)
    
    dec = await groq.decide(
        technical=tech, sentiment=sent, news_social=news,
        exchange=exch, whale=whale_data, risk=risk_res, current_price=price,
        has_position=has_position, last_action=None
    )
    
    # AUTO TRADE EXECUTION
    action = dec.get('action', 'HOLD')
    if action in ['BUY', 'SELL'] and not has_position and risk_res.get('can_trade'):
        try:
            if action == "BUY":
                side = "buy"
                sl = price * 0.985
                tp = price * 1.03
            else:
                side = "sell"
                sl = price * 1.015
                tp = price * 0.97
            
            size = 1
            order = kucoin.place_order(side, size, "XBTUSDTM")
            if order:
                logger.info(f"✅ AUTO TRADE: {action} at ${price:.2f}")
                print(f"✅ AUTO TRADE: {action} at ${price:.2f}")
        except Exception as e:
            logger.error(f"Auto trade error: {e}")
    
    return tech, sent, news, exch, whale_data, risk_res, dec, price, balance, has_position, position

def get_emoji(signal):
    if signal == 'BUY':
        return '🟢'
    elif signal == 'SELL':
        return '🔴'
    else:
        return '⚪'

