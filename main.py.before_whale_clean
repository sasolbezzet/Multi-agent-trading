async def _monitor_sltp_safe():
    """Background monitoring SL/TP setiap 10 detik"""
    logger.info("🟢 SL/TP Monitor started - checking every 10 seconds")
    while True:
        try:
            pos = kucoin.get_position()
            if pos['has_position']:
                entry = pos['entry']
                current = pos['current']
                side = pos['side']
                if side == 'long':
                    if current <= entry * 0.985:
                        logger.info(f"🔴 STOP LOSS HIT! Closing LONG at ${current:.2f}")
                        kucoin.close_position()
                    elif current >= entry * 1.03:
                        logger.info(f"🎯 TAKE PROFIT HIT! Closing LONG at ${current:.2f}")
                        kucoin.close_position()
                else:
                    if current >= entry * 1.015:
                        logger.info(f"🔴 STOP LOSS HIT! Closing SHORT at ${current:.2f}")
                        kucoin.close_position()
                    elif current <= entry * 0.97:
                        logger.info(f"🎯 TAKE PROFIT HIT! Closing SHORT at ${current:.2f}")
                        kucoin.close_position()
            await asyncio.sleep(10)
        except Exception as e:
            logger.error(f"Monitor error: {e}")
            await asyncio.sleep(10)


